@page "/books"
@using LawsonSLab5.Models
@using LawsonSLab5.Services
@inject ILibraryService LibraryService

<PageTitle>Book Management</PageTitle>

<h2>Book Management</h2>

<div class="card mb-4">
    <div class="card-header">
        @(editingBook == null ? "Add New Book" : $"Edit Book – {editingBook.Title}")
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Title</label>
                <input class="form-control" @bind="formBook.Title" placeholder="Title" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Author</label>
                <input class="form-control" @bind="formBook.Author" placeholder="Author" />
            </div>
            <div class="col-md-3">
                <label class="form-label">ISBN</label>
                <input class="form-control" @bind="formBook.ISBN" placeholder="ISBN" />
            </div>
            <div class="col-md-2 d-flex align-items-end gap-2">
                <button class="btn btn-primary" @onclick="SaveBook">
                    @(editingBook == null ? "Add" : "Save")
                </button>
                @if (editingBook != null)
                {
                    <button class="btn btn-secondary" @onclick="CancelEdit">Cancel</button>
                }
            </div>
        </div>
        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert alert-info mt-2">@message</div>
        }
    </div>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Title</th>
            <th>Author</th>
            <th>ISBN</th>
            <th>Available</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in books)
        {
            <tr>
                <td>@book.Id</td>
                <td>@book.Title</td>
                <td>@book.Author</td>
                <td>@book.ISBN</td>
                <td>
                    @if (book.IsAvailable)
                    {
                        <span class="badge bg-success">Available</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Checked Out</span>
                    }
                </td>
                <td>
                    <button class="btn btn-sm btn-warning me-1" @onclick="() => StartEdit(book)">Edit</button>
                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteBook(book.Id)">Delete</button>
                </td>
            </tr>
        }
        @if (books.Count == 0)
        {
            <tr><td colspan="6" class="text-center text-muted">No books in the library yet.</td></tr>
        }
    </tbody>
</table>

@code {
    private List<Book> books = new();
    private Book formBook = new();
    private Book? editingBook = null;
    private string message = string.Empty;

    protected override void OnInitialized()
    {
        LoadBooks();
    }

    private void LoadBooks()
    {
        books = LibraryService.GetBooks();
    }

    private void SaveBook()
    {
        if (string.IsNullOrWhiteSpace(formBook.Title) ||
            string.IsNullOrWhiteSpace(formBook.Author))
        {
            message = "Title and Author are required.";
            return;
        }

        if (editingBook == null)
        {
            LibraryService.AddBook(new Book
            {
                Title  = formBook.Title,
                Author = formBook.Author,
                ISBN   = formBook.ISBN
            });
            message = $"'{formBook.Title}' added successfully.";
        }
        else
        {
            editingBook.Title  = formBook.Title;
            editingBook.Author = formBook.Author;
            editingBook.ISBN   = formBook.ISBN;
            LibraryService.EditBook(editingBook);
            message = $"'{formBook.Title}' updated successfully.";
        }

        CancelEdit();
        LoadBooks();
    }

    private void StartEdit(Book book)
    {
        editingBook = book;
        formBook = new Book
        {
            Id     = book.Id,
            Title  = book.Title,
            Author = book.Author,
            ISBN   = book.ISBN
        };
        message = string.Empty;
    }

    private void CancelEdit()
    {
        editingBook = null;
        formBook    = new Book();
    }

    private void DeleteBook(int bookId)
    {
        LibraryService.DeleteBook(bookId);
        message = "Book deleted.";
        LoadBooks();
    }
}
