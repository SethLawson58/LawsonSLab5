@page "/users"
@using LawsonSLab5.Models
@using LawsonSLab5.Services
@inject ILibraryService LibraryService

<PageTitle>User Management</PageTitle>

<h2>User Management</h2>

<!-- Add / Edit Form -->
<div class="card mb-4">
    <div class="card-header">
        @(editingUser == null ? "Add New User" : $"Edit User – {editingUser.Name}")
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Name</label>
                <input class="form-control" @bind="formUser.Name" placeholder="Full Name" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Email</label>
                <input class="form-control" @bind="formUser.Email" placeholder="Email" />
            </div>
            <div class="col-md-2 d-flex align-items-end gap-2">
                <button class="btn btn-primary" @onclick="SaveUser">
                    @(editingUser == null ? "Add" : "Save")
                </button>
                @if (editingUser != null)
                {
                    <button class="btn btn-secondary" @onclick="CancelEdit">Cancel</button>
                }
            </div>
        </div>
        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert alert-info mt-2">@message</div>
        }
    </div>
</div>

<!-- User List -->
<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in users)
        {
            <tr>
                <td>@user.Id</td>
                <td>@user.Name</td>
                <td>@user.Email</td>
                <td>
                    <button class="btn btn-sm btn-warning me-1" @onclick="() => StartEdit(user)">Edit</button>
                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteUser(user.Id)">Delete</button>
                </td>
            </tr>
        }
        @if (users.Count == 0)
        {
            <tr><td colspan="5" class="text-center text-muted">No users registered yet.</td></tr>
        }
    </tbody>
</table>

@code {
    private List<User> users = new();
    private User formUser = new();
    private User? editingUser = null;
    private string message = string.Empty;

    protected override void OnInitialized()
    {
        LoadUsers();
    }

    private void LoadUsers()
    {
        users = LibraryService.GetUsers();
    }

    private void SaveUser()
    {
        if (string.IsNullOrWhiteSpace(formUser.Name) ||
            string.IsNullOrWhiteSpace(formUser.Email))
        {
            message = "Name and Email are required.";
            return;
        }

        if (editingUser == null)
        {
            LibraryService.AddUser(new User
            {
                Name = formUser.Name,
                Email = formUser.Email,
            });
            message = $"User '{formUser.Name}' added successfully.";
        }
        else
        {
            editingUser.Name = formUser.Name;
            editingUser.Email = formUser.Email;
            LibraryService.EditUser(editingUser);
            message = $"User '{formUser.Name}' updated successfully.";
        }

        CancelEdit();
        LoadUsers();
    }

    private void StartEdit(User user)
    {
        editingUser = user;
        formUser = new User
        {
            Id = user.Id,
            Name = user.Name,
            Email = user.Email,
        };
        message = string.Empty;
    }

    private void CancelEdit()
    {
        editingUser = null;
        formUser = new User();
    }

    private void DeleteUser(int userId)
    {
        LibraryService.DeleteUser(userId);
        message = "User deleted.";
        LoadUsers();
    }
}
